# Copy to .env and adjust. Local mode needs nothing set — these are the defaults.

# local  -> in-memory table/bus/blob, no external deps (default)
# infra  -> real ScyllaDB (Alternator) + NATS JetStream + MinIO via docker-compose
APP_ENV=local

# --- Data plane (only used when APP_ENV=infra) ---
SCYLLA_ENDPOINT=http://localhost:8000     # Alternator (DynamoDB API)
SCYLLA_REGION=us-east-1
SCYLLA_TABLE=platform
NATS_URL=nats://localhost:4222
S3_ENDPOINT=http://localhost:9000         # MinIO
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=eeof-blobs

# --- Model provider ---
# Every heavy stage (question authoring, user-simulator, judge scoring, and the
# 401k agent-under-test) resolves its model through this one switch — nothing in
# the code hard-codes a vendor. Providers form a FALLBACK CHAIN:
#   primary (MODEL_PROVIDER) -> MODEL_FALLBACK -> echo (offline safety net)
# Any link whose credentials are absent is skipped. Default wiring is Azure
# OpenAI GPT-4 primary with Groq as the fallback, so if the Azure deployment is
# not configured, calls resolve straight to Groq; if neither is set, to echo.
#   azure_openai -> Azure OpenAI Chat Completions, GPT-4 (default primary)
#   groq         -> Groq OpenAI-compatible endpoint (default fallback)
#   anthropic    -> real Claude (needs ANTHROPIC_API_KEY)
#   bedrock      -> AWS Bedrock Converse API
#   echo         -> deterministic, offline fallback (always boots)
MODEL_PROVIDER=azure_openai
MODEL_NAME=gpt-4
MODEL_FALLBACK=groq              # secondary backend; "" disables (primary -> echo)

# Azure OpenAI (GPT-4) — the primary. Fill these in to hit a real deployment;
# leave blank to let the chain fall through to Groq (then echo).
AZURE_OPENAI_ENDPOINT=            # https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4     # your GPT-4 deployment name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Groq (fallback) — OpenAI-compatible, hosted open-weight models, free tier.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ENDPOINT=https://api.groq.com/openai/v1

# Anthropic / Bedrock (only when selected as primary or fallback)
ANTHROPIC_API_KEY=

# --- Service ports (in-cluster; the orchestrator is the only public edge) ---
API_ORCHESTRATION_PORT=8080
PERSONA_SVC_PORT=8091
JUDGE_REGISTRY_PORT=8092
QGEN_SVC_PORT=8093
SIMULATION_SVC_PORT=8094
EVALUATION_SVC_PORT=8095
OBSERVABILITY_SVC_PORT=8096
AGENT_UNDER_TEST_PORT=8097        # demo 401k retirement-planning agent (REST)
SELF_HEAL_SVC_PORT=8098          # closed-loop remediation (self-heal)

# Dev auth: any bearer token maps to this tenant/workspace in local mode.
DEV_TENANT=acme
DEV_WORKSPACE=trust-and-safety
