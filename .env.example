# Copy to .env and adjust. Local mode needs nothing set — these are the defaults.

# local  -> in-memory table/bus/blob, no external deps (default)
# infra  -> real ScyllaDB (Alternator) + NATS JetStream + MinIO via docker-compose
APP_ENV=local

# --- Data plane (only used when APP_ENV=infra) ---
SCYLLA_ENDPOINT=http://localhost:8000     # Alternator (DynamoDB API)
SCYLLA_REGION=us-east-1
SCYLLA_TABLE=platform
NATS_URL=nats://localhost:4222
S3_ENDPOINT=http://localhost:9000         # MinIO
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=eeof-blobs

# --- Model provider ---
# Every heavy stage (question authoring, user-simulator, judge scoring, and the
# 401k agent-under-test) resolves its model through this one switch — nothing in
# the code hard-codes a vendor. Default is Azure OpenAI GPT-4.
#   azure_openai -> Azure OpenAI Chat Completions, GPT-4 (default)
#   anthropic    -> real Claude (needs ANTHROPIC_API_KEY)
#   bedrock      -> AWS Bedrock Converse API
#   echo         -> deterministic, offline fallback (used automatically when the
#                   azure_openai credentials below are blank, so it always boots)
MODEL_PROVIDER=azure_openai
MODEL_NAME=gpt-4

# Azure OpenAI (GPT-4). Fill these in to hit a real deployment; leave blank to
# run fully offline on the deterministic echo provider.
AZURE_OPENAI_ENDPOINT=            # https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4     # your GPT-4 deployment name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Anthropic / Bedrock (only when MODEL_PROVIDER is set to them)
ANTHROPIC_API_KEY=

# --- Service ports (in-cluster; the orchestrator is the only public edge) ---
API_ORCHESTRATION_PORT=8080
PERSONA_SVC_PORT=8091
JUDGE_REGISTRY_PORT=8092
QGEN_SVC_PORT=8093
SIMULATION_SVC_PORT=8094
EVALUATION_SVC_PORT=8095
OBSERVABILITY_SVC_PORT=8096
AGENT_UNDER_TEST_PORT=8097        # demo 401k retirement-planning agent (REST)

# Dev auth: any bearer token maps to this tenant/workspace in local mode.
DEV_TENANT=acme
DEV_WORKSPACE=trust-and-safety
